---
// Self-hosted fonts (only the weights actually used)
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/700.css";

import "../styles/global.css";
import { site } from "../data/site.ts";

interface Props {
  title?: string;
  description?: string;
  /** OG/Twitter card image — absolute path under /public. */
  image?: string;
  /** og:type — "website" for the home page, "article" for case studies. */
  type?: "website" | "article";
  /** Page-specific JSON-LD. Falls back to the Person + WebSite identity graph. */
  structuredData?: object;
}

const {
  title = `${site.name} — ${site.currentTitle}`,
  description = site.metaDescription,
  image = site.ogImage,
  type = "website",
  structuredData,
} = Astro.props;

// Astro.site is set in astro.config.mjs, so these resolve to absolute URLs —
// required by Open Graph (relative image paths are silently dropped by crawlers).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(image, Astro.site).href;

// Identity graph: a single Person node other pages can reference by @id, plus
// the WebSite. sameAs ties the social profiles into one entity for Google.
const personId = `${site.url}/#person`;
const identityGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: site.name,
      url: site.url,
      image: ogImageUrl,
      jobTitle: site.jobTitle,
      email: `mailto:${site.email}`,
      worksFor: { "@type": "Organization", name: site.currentCompany },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Ottawa",
        addressRegion: "ON",
        addressCountry: "CA",
      },
      sameAs: site.socials
        .filter((s) => s.href.startsWith("http"))
        .map((s) => s.href),
      knowsAbout: [
        "Site Reliability Engineering",
        "DevOps",
        "DevSecOps",
        "Kubernetes",
        "Terraform",
        "Amazon Web Services",
        "CI/CD",
        "Observability",
        "AIOps",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      url: site.url,
      name: `${site.name} — Portfolio`,
      inLanguage: "en",
      publisher: { "@id": personId },
    },
  ],
};
const jsonLd = structuredData ?? identityGraph;
---

<!doctype html>
<html lang="en" data-tz={site.timezone}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />
    <link rel="canonical" href={canonical} />

    <!-- Icons & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={`${site.name} — Portfolio`} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={`${site.name}, ${site.jobTitle}`}
    />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- Theme color tracks resolved theme; updated by the bootstrap script -->
    <meta name="theme-color" content="#eff1f5" id="theme-color" />

    <!-- No-flash theme bootstrap: stored choice wins, else follow system. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var dark =
            stored === "dark" ||
            (stored === null &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);
          if (dark) document.documentElement.setAttribute("data-theme", "dark");
          var tc = document.querySelector("#theme-color");
          if (tc) tc.setAttribute("content", dark ? "#1e1e2e" : "#eff1f5");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Shared client behavior: theme toggle + active-section nav highlight. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var tc = document.querySelector("#theme-color");
        function paint() {
          var dark = root.getAttribute("data-theme") === "dark";
          document.querySelectorAll("[data-toggle]").forEach(function (b) {
            var i = b.querySelector("[data-ti]");
            var l = b.querySelector("[data-tl]");
            if (i) i.textContent = dark ? "☀" : "☾";
            if (l) l.textContent = dark ? "light" : "dark";
            b.setAttribute(
              "aria-label",
              dark ? "Switch to light theme" : "Switch to dark theme",
            );
          });
          if (tc) tc.setAttribute("content", dark ? "#1e1e2e" : "#eff1f5");
        }
        paint();
        document.querySelectorAll("[data-toggle]").forEach(function (b) {
          b.addEventListener("click", function () {
            var dark = root.getAttribute("data-theme") === "dark";
            if (dark) root.removeAttribute("data-theme");
            else root.setAttribute("data-theme", "dark");
            try {
              localStorage.setItem("theme", dark ? "light" : "dark");
            } catch (e) {}
            paint();
          });
        });

        // Highlight the nav item for whichever section is in view.
        var links = [].slice.call(document.querySelectorAll("nav.sect a"));
        var sections = document.querySelectorAll("section[id]");
        if (links.length && sections.length && "IntersectionObserver" in window) {
          var io = new IntersectionObserver(
            function (es) {
              es.forEach(function (e) {
                if (e.isIntersecting) {
                  links.forEach(function (l) {
                    l.classList.toggle(
                      "on",
                      (l.getAttribute("href") || "").indexOf("#" + e.target.id) >= 0,
                    );
                  });
                }
              });
            },
            { rootMargin: "-30% 0px -60% 0px" },
          );
          sections.forEach(function (s) {
            io.observe(s);
          });
        }
      })();
    </script>
  </body>
</html>
