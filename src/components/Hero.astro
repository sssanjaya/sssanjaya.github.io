---
import { site } from "../data/site.ts";

const idx = [
  { n: "01", label: "Experience", href: "#experience" },
  { n: "02", label: "Projects", href: "#projects" },
  { n: "03", label: "About", href: "#about" },
  { n: "04", label: "Contact", href: "#contact" },
];
---

<header>
  <div class="wrap">
    <div class="hero-top">
      <div style="grid-column: 1 / 4;">
        <h1>Reliable<br />by <span class="r">design.</span></h1>
      </div>
      <nav class="idx" aria-label="Section index">
        <span class="n" style="display:block; margin-bottom:4px;">[ INDEX ]</span>
        {
          idx.map((i) => (
            <a href={i.href}>
              <span class="n">{i.n}</span> <b>{i.label}</b>
            </a>
          ))
        }
      </nav>
    </div>

    <div class="lede">
      <p>
        I'm <b>{site.name}</b>, a {site.currentTitle} at {site.currentCompany}.
        For <b>seven years</b> I've built cloud infrastructure that ships fast and
        stays up — Kubernetes platforms, Terraform everywhere, and a fleet of <b
          >40+ edge devices</b
        > running in the field. Boring deploys are a feature.
      </p>
      <span class="scroll">↓ SCROLL / 01</span>
    </div>

    <div class="statrow">
      {
        site.stats.map((s) => (
          <div>
            <div class="n">{s.value}</div>
            <div class="l">{s.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</header>
