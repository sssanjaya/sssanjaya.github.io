---
import { experience } from "../data/experience.ts";
---

<section id="experience">
  <div class="slabel">
    <span class="ix">#</span><span class="tx">Experience</span><span class="ln"></span>
  </div>
  {
    experience.map((r) => (
      <div class="entry">
        <div class="when">{r.year}</div>
        <div>
          <h3>
            {r.title} <span class="co">· {r.company}</span>
          </h3>
          <p>{r.blurb}</p>
        </div>
      </div>
    ))
  }
</section>
