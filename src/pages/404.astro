---
import Base from "../layouts/Base.astro";
import Rail from "../components/Rail.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { site } from "../data/site.ts";
---

<Base title={`404 — ${site.name}`} description="Page not found.">
  <div class="shell">
    <Rail />
    <main class="content">
      <div class="notfound">
        <div class="nf-code mono"><span class="ix">404</span> — not found</div>
        <p class="nf-cmd mono">
          <span class="pr">$</span> cat <span id="nf-path">.</span><br />
          <span class="er">zsh:</span> no such file or directory
        </p>
        <a class="more mono" href="/">→ cd ~</a>
      </div>
      <SiteFooter />
    </main>
  </div>
</Base>

<style>
  .notfound { padding: 80px 0 0; }
  .nf-code { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; }
  .nf-code .ix { color: var(--mauve); }
  .nf-cmd { margin-top: 20px; font-size: 14px; line-height: 1.9; color: var(--mut); }
  .nf-cmd .pr { color: var(--green); }
  .nf-cmd .er { color: var(--peach); }
  .notfound .more {
    font-family: var(--mono); font-size: 13px; color: var(--blue);
    margin-top: 22px; display: inline-block; border-bottom: 1px solid transparent;
  }
  .notfound .more:hover { border-bottom-color: var(--blue); }
</style>

<script is:inline>
  var p = document.getElementById("nf-path");
  if (p) p.textContent = location.pathname;
</script>
