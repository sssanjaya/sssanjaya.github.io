---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import { site } from "../../data/site.ts";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({ params: { id: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const personId = `${site.url}/#person`;

// TechArticle for the case study, authored by the referenced Person entity.
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: project.data.title,
  description: project.data.summary,
  url: canonical,
  image: new URL(site.ogImage, Astro.site).href,
  keywords: project.data.tags.join(", "),
  inLanguage: "en",
  author: { "@type": "Person", "@id": personId, name: site.name },
  publisher: { "@id": personId },
  mainEntityOfPage: canonical,
};
---

<Base
  title={`${project.data.title} — ${site.name}`}
  description={project.data.summary}
  type="article"
  structuredData={articleJsonLd}
>
  <TopBar />
  <main>
    <article class="article">
      <div class="wrap">
        <a class="back" href="/#projects">← Index / Projects</a>
        <span class="pn">[ {project.data.kind} ]</span>
        <h1 class="title">{project.data.title}</h1>
        <p class="summary">{project.data.summary}</p>
        <div class="tags" style="margin-top:16px;">
          {project.data.tags.map((t) => <span class="tag">{t}</span>)}
          {
            project.data.links.map((l) => (
              <a class="tag" href={l.href} target="_blank" rel="noopener">
                {l.label} ↗
              </a>
            ))
          }
        </div>
        <div class="prose">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <footer>
    <div class="wrap">
      <div class="inner">
        <span>Designed &amp; built by {site.name}</span>
        <span>Astro · No trackers · View source welcome</span>
      </div>
    </div>
  </footer>
</Base>
